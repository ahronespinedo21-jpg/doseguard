    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "8.0.2",
    "@ionic/angular": "^8.8.3",
    "@ionic/angular-toolkit": "^12.3.0",
    "firebase": "^12.13.0",
