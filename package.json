{
  "name": "@doseguard/ui",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve doseguard --port 4200",
    "build": "ng build doseguard",
    "dev": "ng serve doseguard --port 4200 --open",
    "ionic": "ng serve doseguard --port 8100 --open",
    "serve-ionic": "ng serve doseguard --port=8100",
    "ionic-serve": "node ionic-serve.js",
    "ionic-serve-wrapper": "node ionic-serve.js",
    "watch": "ng build doseguard --watch --configuration development",
    "test": "ng test doseguard",
    "lint": "ng lint doseguard",
    "dev:network": "ng serve doseguard --host 0.0.0.0 --port 4200",
    "ionic:network": "ng serve doseguard --host 0.0.0.0 --port 8100",
    "dev:network:open": "ng serve doseguard --host 0.0.0.0 --port 4200 --open",
    "ionic:network:open": "ng serve doseguard --host 0.0.0.0 --port 8100 --open"
  },
  "dependencies": {
